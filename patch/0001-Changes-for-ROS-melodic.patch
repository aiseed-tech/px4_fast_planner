@@ -34,7 +35,7 @@ include_directories(
     ${catkin_INCLUDE_DIRS}
     ${Eigen3_INCLUDE_DIRS} 
     ${PCL_INCLUDE_DIRS}
-    ${NLOPT_INCLUDE_DIR}  
+    ${nlopt_INCLUDE_DIRS}
 )
 
